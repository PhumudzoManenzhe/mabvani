NODE_ENV=development
PORT=3000

# Vercel frontend URL. Use a comma-separated list if more origins are needed.
CLIENT_URL=http://localhost:5500

# Render PostgreSQL. Server-only. Never expose this value in frontend files.
DATABASE_URL=postgresql://username:password@hostname:5432/database_name

# Supabase Auth.
# SUPABASE_ANON_KEY may be used by the frontend because it is the public anon key.
