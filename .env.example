NODE_ENV=development
PORT=3000

# Vercel frontend URL. Use a comma-separated list if more origins are needed.
CLIENT_URL=http://localhost:5500

# Render PostgreSQL. Server-only. Never expose this value in frontend files.
DATABASE_URL=postgresql://username:password@hostname:5432/database_name

# Supabase Auth.
# SUPABASE_ANON_KEY may be used by the frontend because it is the public anon key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_public_anon_key
# Server-only. Never expose this key in client files or browser configuration.
SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key

# Cloudinary.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
# Server-only. Never expose this value in frontend files.
CLOUDINARY_API_SECRET=

# Storage provider.
STORAGE_PROVIDER=cloudinary

# Future AWS S3 configuration placeholders. Keep these server-only.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
